{
   "action": {
      "default_popup": "pop/pop.html",
      "default_title": "__MSG_action_default_title__"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [
      {
         "js": [
            "content.js"
         ],
         "matches": [
            "https://discord.com/*"
         ],
         "run_at": "document_start"
      }
   ],
   "default_locale": "en",
   "description": "Local test build: license checks stubbed, no hypercavs calls from token flow. Not for redistribution.",
   "icons": {
      "48": "icons/icon_48.png",
      "128": "icons/icon_128.png"
   },
   "manifest_version": 3,
   "name": "Unlocked Discord Exporter (TEST — no license server)",
   "permissions": [
      "activeTab",
      "storage",
      "downloads",
      "scripting"
   ],
   "version": "2.0.0"
}
