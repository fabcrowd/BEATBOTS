{
  "name": "beatbots",
  "version": "1.0.0",
  "description": "BEATBOTS - Target Checkout Automation",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently -k -n VITE,ELECTRON \"vite\" \"cross-env NODE_ENV=development electronmon dist-electron/main/index.js\"",
    "electron:build": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "lint": "eslint src --ext ts,tsx",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.beatbots.app",
    "productName": "BEATBOTS",
    "copyright": "Copyright © 2026 BEATBOTS",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "!dist-electron/**/*.map"
    ],
    "extraResources": [
      { "from": "build/sounds", "to": "sounds", "filter": ["**/*"] }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico",
      "artifactName": "BEATBOTS-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "artifactName": "BEATBOTS-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "BEATBOTS",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": null
  },
  "keywords": [],
  "author": "BEATBOTS",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.3",
    "eslint": "^9.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "dependencies": {
    "puppeteer-core": "^23.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  }
}
