{
  "manifest_version": 3,
  "name": "Target Checkout Helper",
  "version": "2.0.0",
  "description": "Automates Target.com and Walmart.com checkout steps — Add to Cart through Order Review. You place the final order.",
  "permissions": ["storage", "tabs", "alarms", "cookies", "debugger", "declarativeNetRequest", "browsingData", "identity", "nativeMessaging"],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "blocking", "enabled": true, "path": "rules/blocking.json" }
    ]
  },
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dropPollingTiming.js", "core/hosts.js", "core/jigAddress.js", "content.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://*.target.com/*"],
      "js": ["main_world.js"],
      "run_at": "document_end",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.walmart.com/*"],
      "js": ["walmart-main-world.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.walmart.com/*"],
      "js": ["dropPollingTiming.js", "core/hosts.js", "core/jigAddress.js", "walmart-content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
